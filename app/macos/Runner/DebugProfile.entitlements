<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>com.apple.security.app-sandbox</key>
	<true/>
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
	<key>com.apple.security.network.server</key>
	<true/>
	<key>com.apple.security.network.client</key>
	<true/>
	<!-- Sandboxed macOS apps need this for flutter_secure_storage and the native
	     Google Sign-In SDK to reach the Keychain. Without it, both throw
	     errSecMissingEntitlement (-34018), which surfaces as a bootstrap warning
	     and Google sign-in's google_providerConfigurationError. -->
	<key>keychain-access-groups</key>
	<array>
		<string>$(AppIdentifierPrefix)com.salahbahzad.securePlayer</string>
	</array>
</dict>
</plist>
