{
  "$meta": {
    "name": "Salah Bahzad Design System",
    "version": "0.1.0",
    "note": "Approximate values eyeballed from brand assets; tune as needed. Mirrors tokens.css / tokens.scss."
  },
  "color": {
    "brand": {
      "blue": "#2C6FB3",
      "blueBright": "#3E8EDE",
      "navy": "#1E3A5F",
      "green": "#46A33E",
      "greenDeep": "#2F7D2A",
      "red": "#E23B33",
      "mustard": "#F3C12E",
      "mint": "#86C7A6",
      "orange": "#E8743B",
      "purple": "#6E3FA6",
      "pink": "#E85FA8",
      "cream": "#F3F2E0",
      "ink": "#1A1A1A",
      "mascotSkin": "#E7B488",
      "mascotBeard": "#3A2A1F"
    },
    "primary": {
      "50": "#EAF2FB", "100": "#D2E4F6", "200": "#A8C9EC", "300": "#7CADE1", "400": "#5495D6",
      "500": "#3E8EDE", "600": "#2C6FB3", "700": "#245C95", "800": "#1E4A78", "900": "#1E3A5F"
    },
    "accent": {
      "50": "#EBF5E9", "100": "#D4EACF", "200": "#ABD7A3", "300": "#7FC375", "400": "#5BB052",
      "500": "#4FA945", "600": "#46A33E", "700": "#357E30", "800": "#2A6326", "900": "#1F491D"
    },
    "neutral": {
      "0": "#FFFFFF", "25": "#FBFBF7", "50": "#F6F6F0", "100": "#ECEBE2", "200": "#DAD8CC",
      "300": "#BFBDB0", "400": "#98968A", "500": "#6F6E63", "600": "#54534A", "700": "#3D3C35",
      "800": "#2A2924", "900": "#1A1A16"
    },
    "semantic": {
      "success": { "fg": "#2A6326", "base": "#46A33E", "bg": "#EBF5E9", "border": "#ABD7A3" },
      "danger":  { "fg": "#A52A24", "base": "#E23B33", "bg": "#FBE8E6", "border": "#F3B4B0" },
      "warning": { "fg": "#8A6A00", "base": "#F3C12E", "bg": "#FEF6DD", "border": "#F5E2A0" },
      "info":    { "fg": "#1E4A78", "base": "#3E8EDE", "bg": "#E8F2FC", "border": "#A8C9EC" }
    },
    "subject": {
      "blue":    { "base": "#3E8EDE", "bg": "#E8F2FC", "deep": "#1E4A78" },
      "green":   { "base": "#46A33E", "bg": "#EBF5E9", "deep": "#2A6326" },
      "red":     { "base": "#E23B33", "bg": "#FBE8E6", "deep": "#A52A24" },
      "mustard": { "base": "#F3C12E", "bg": "#FEF6DD", "deep": "#8A6A00" },
      "mint":    { "base": "#86C7A6", "bg": "#EAF5EF", "deep": "#2F6B52" },
      "orange":  { "base": "#E8743B", "bg": "#FCEDE3", "deep": "#A24A1E" },
      "purple":  { "base": "#6E3FA6", "bg": "#F0E9F8", "deep": "#4A2A72" },
      "pink":    { "base": "#E85FA8", "bg": "#FCE8F2", "deep": "#9A2E64" }
    },
    "role": {
      "bg": "#FBFBF7",
      "surface": "#FFFFFF",
      "surfaceSunken": "#F6F6F0",
      "border": "#DAD8CC",
      "borderStrong": "#BFBDB0",
      "text": "#1A1A16",
      "textMuted": "#6F6E63",
      "textSubtle": "#98968A",
      "primary": "#2C6FB3",
      "primaryHover": "#245C95",
      "primaryActive": "#1E4A78",
      "accent": "#46A33E",
      "onPrimary": "#FFFFFF",
      "link": "#2C6FB3",
      "linkHover": "#245C95",
      "focusRing": "rgba(62,142,222,0.45)",
      "scrim": "rgba(26,26,22,0.45)"
    }
  },
  "font": {
    "ui": "\"Nunito Sans\", ui-sans-serif, system-ui, -apple-system, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif",
    "display": "\"Permanent Marker\", \"Nunito Sans\", cursive",
    "script": "\"Caveat\", \"Permanent Marker\", cursive",
    "mono": "ui-monospace, \"Cascadia Code\", \"Fira Code\", Menlo, Consolas, monospace"
  },
  "fontSize": {
    "xs": "0.75rem", "sm": "0.875rem", "base": "1rem", "md": "1.125rem", "lg": "1.25rem",
    "xl": "1.5rem", "2xl": "1.875rem", "3xl": "2.25rem", "4xl": "3rem", "5xl": "3.75rem", "6xl": "4.5rem"
  },
  "fontWeight": { "regular": 400, "semibold": 600, "bold": 700, "extrabold": 800, "black": 900 },
  "lineHeight": { "tight": 1.15, "snug": 1.3, "normal": 1.5, "relaxed": 1.65 },
  "letterSpacing": { "tight": "-0.01em", "normal": "0", "wide": "0.02em", "wider": "0.06em" },
  "space": {
    "0": "0", "1": "0.25rem", "2": "0.5rem", "3": "0.75rem", "4": "1rem", "5": "1.25rem",
    "6": "1.5rem", "7": "1.75rem", "8": "2rem", "10": "2.5rem", "12": "3rem", "16": "4rem",
    "20": "5rem", "24": "6rem"
  },
  "radius": {
    "xs": "4px", "sm": "6px", "md": "10px", "lg": "14px", "xl": "20px", "2xl": "28px",
    "pill": "999px", "circle": "50%"
  },
  "shadow": {
    "xs": "0 1px 2px rgba(26,26,22,0.06)",
    "sm": "0 2px 6px rgba(26,26,22,0.08)",
    "md": "0 6px 16px rgba(26,26,22,0.10)",
    "lg": "0 14px 32px rgba(26,26,22,0.12)",
    "xl": "0 24px 48px rgba(26,26,22,0.16)",
    "focus": "0 0 0 3px rgba(62,142,222,0.45)"
  },
  "motion": {
    "durFast": "150ms", "dur": "250ms", "durSlow": "400ms",
    "easeStandard": "cubic-bezier(0.2,0.8,0.2,1)",
    "easeOut": "cubic-bezier(0,0,0.2,1)",
    "easeIn": "cubic-bezier(0.4,0,1,1)"
  },
  "z": { "base": 0, "dropdown": 1000, "sticky": 1100, "overlay": 1200, "modal": 1300, "toast": 1400, "tooltip": 1500 },
  "breakpoint": { "sm": "480px", "md": "768px", "lg": "1024px", "xl": "1280px", "2xl": "1536px" }
}
