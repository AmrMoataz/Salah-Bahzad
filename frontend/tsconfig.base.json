{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ES2022",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@sb/shared/ui": ["libs/shared/ui/src/index.ts"],
      "@sb/shared/data-access": ["libs/shared/data-access/src/index.ts"],
      "@sb/shared/util": ["libs/shared/util/src/index.ts"],
      "@sb/student-portal/data-access": ["libs/student-portal/data-access/src/index.ts"],
      "@sb/student-portal/feature-assessment": ["libs/student-portal/feature-assessment/src/index.ts"],
      "@sb/student-portal/feature-catalogue": ["libs/student-portal/feature-catalogue/src/index.ts"],
      "@sb/student-portal/feature-home": ["libs/student-portal/feature-home/src/index.ts"],
      "@sb/student-portal/feature-profile": ["libs/student-portal/feature-profile/src/index.ts"],
      "@sb/student-portal/feature-sessions": ["libs/student-portal/feature-sessions/src/index.ts"],
      "@sb/student-portal/feature-auth": ["libs/student-portal/feature-auth/src/index.ts"],
      "@sb/student-portal/feature-shell": ["libs/student-portal/feature-shell/src/index.ts"],
      "@sb/admin-portal/feature-attendance": ["libs/admin-portal/feature-attendance/src/index.ts"],
      "@sb/admin-portal/feature-audit": ["libs/admin-portal/feature-audit/src/index.ts"],
      "@sb/admin-portal/feature-auth": ["libs/admin-portal/feature-auth/src/index.ts"],
      "@sb/admin-portal/feature-shell": ["libs/admin-portal/feature-shell/src/index.ts"],
      "@sb/admin-portal/feature-dashboard": ["libs/admin-portal/feature-dashboard/src/index.ts"],
      "@sb/admin-portal/feature-staff": ["libs/admin-portal/feature-staff/src/index.ts"],
      "@sb/admin-portal/feature-students": ["libs/admin-portal/feature-students/src/index.ts"],
      "@sb/admin-portal/feature-sessions": ["libs/admin-portal/feature-sessions/src/index.ts"],
      "@sb/admin-portal/feature-codes": ["libs/admin-portal/feature-codes/src/index.ts"],
      "@sb/admin-portal/feature-taxonomy": ["libs/admin-portal/feature-taxonomy/src/index.ts"],
