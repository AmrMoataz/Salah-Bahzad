# Angular's package peers are pinned to exact versions, but @angular/fire@20
# declares loose `^20.0.0` peers (incl. platform-browser-dynamic, platform-server,
# firebase-tools). npm 7+'s strict peer resolver can't reconcile those, so install
# with the legacy resolver. This keeps a plain `npm install` / `npm ci` working.
legacy-peer-deps=true
